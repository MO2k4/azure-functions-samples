{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Azure": "Warning"
    }
  },
  "Settlement": {
    "PerPaymentDelayMs": 50,
    "FailureRate": 0.02
  },
  "Queue": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "QueueName": "settlement-batches",
    "MaxBatchMessages": 8,
    "VisibilityTimeoutSeconds": 1800,
    "IdlePollingDelayMs": 5000
  }
}
